<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <title>Test Supabase</title>
  <style>
    body { font-family: system-ui, sans-serif; padding: 20px; }
    button { margin: 8px 0; padding: 8px 12px; }
    .result { margin-top: 10px; font-weight: bold; }
    .error { margin-top: 10px; color: #cc0000; }
  </style>
</head>
<body>
  <h1>Test Supabase</h1>

  <button id="checkMatches">Matches prüfen</button>

  <div class="result" id="result"></div>
  <div class="error" id="error"></div>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script>
    const supabaseUrl = "https://tmadmhayyudwbbzxfqnl.supabase.co";
    const supabaseKey = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRtYWRtaGF5eXVkd2JienhmcW5sIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMwMTA3ODIsImV4cCI6MjA5ODU4Njc4Mn0.cu70uZwFw_eKOAuzHQijgokrDrpDN4C4kCRgfQfwUxY";
    const supabase = window.supabase.createClient(supabaseUrl, supabaseKey);

    const checkBtn = document.getElementById("checkMatches");
    const resultEl = document.getElementById("result");
    const errorEl = document.getElementById("error");

    checkBtn.addEventListener("click", async () => {
      resultEl.textContent = "Lade Matches...";
      errorEl.textContent = "";

      try {
        const { data, error } = await supabase
          .from("matches")
          .select("*");

        if (error) {
          resultEl.textContent = "Fehler bei Supabase";
          errorEl.textContent = "Supabase-Fehler: " + error.message;
          return;
        }

        if (!data || data.length === 0) {
          resultEl.textContent = "Keine Matches gefunden.";
          return;
        }

        resultEl.textContent = "Gefundene Matches:\n" + data.map(m => m.code).join(", ");
      } catch (e) {
        resultEl.textContent = "Unbekannter Fehler";
        errorEl.textContent = "Fehler: " + e.message;
      }
    });
  </script>
</body>
</html>
